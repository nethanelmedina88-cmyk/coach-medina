rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // clients/{clientId} — תיק מתאמן (משקלים, צ'ק-אינים, אימונים, תזונה)
    match /clients/{clientId} {
      allow read, write: if request.auth != null;
    }

    // meta/settings — PIN של המאמן
    match /meta/settings {
      allow read, write: if request.auth != null;
    }

    // כל השאר חסום
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
